        <mxCell id="koovAlx03edogV21XalM-1" value="&lt;h3 data-start=&quot;0&quot; data-end=&quot;48&quot; data-section-id=&quot;1y8r7ov&quot;&gt;Phân tích logic:&lt;/h3&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;Việc để &lt;span data-start=&quot;58&quot; data-end=&quot;93&quot; style=&quot;&quot;&gt;AUTHORS là thuộc tính của BOOKS&lt;/span&gt; là sai vì:&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span data-start=&quot;110&quot; data-end=&quot;134&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;span data-start=&quot;110&quot; data-end=&quot;134&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Sai bản chất dữ liệu&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;:&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- Tác giả không phải là thuộc tính đơn giản (như tên sách, giá tiền), mà là &lt;/span&gt;&lt;strong data-start=&quot;216&quot; data-end=&quot;241&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;một đối tượng độc lập&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; có nhiều thông tin riêng (năm sinh, tiểu sử,...)&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span data-start=&quot;297&quot; data-end=&quot;338&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;-&lt;/b&gt;&amp;nbsp;&lt;/span&gt;&lt;span data-start=&quot;297&quot; data-end=&quot;338&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Gây dư thừa dữ liệu&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;:&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ Một tác giả viết nhiều sách -. thông tin bị lặp lại nhiều lần.&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ Ví dụ: Nguyễn Nhật Ánh có 100 sách -&amp;gt; bị lưu 100 lần.&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span data-start=&quot;468&quot; data-end=&quot;500&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;span data-start=&quot;468&quot; data-end=&quot;500&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Khó bảo trì&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;:&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ Sửa tiểu sử -&amp;gt; phải sửa ở 100 dòng -&amp;gt; dễ sai lệch dữ liệu.&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span data-start=&quot;568&quot; data-end=&quot;595&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ Không đáp ứng nghiệp vụ&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;:&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;+ Yêu cầu là &lt;/span&gt;&lt;span data-start=&quot;612&quot; data-end=&quot;658&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;click vào tác giả để xem danh sách sách khác -&amp;gt;&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;50&quot; data-end=&quot;104&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Nếu chỉ là thuộc tính thì &lt;/span&gt;&lt;span data-start=&quot;691&quot; data-end=&quot;757&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;không truy vấn được danh sách sách theo tác giả một cách chuẩn&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="260" y="530" width="550" height="500" as="geometry" />
        </mxCell>
      </root>
